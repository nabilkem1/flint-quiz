{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "searchLocation": { "value": "${SEARCH_LOCATION=${AZURE_LOCATION}}" },
    "prefix": { "value": "fq" },
    "supportedLanguages": { "value": ["en", "fr", "es"] },
    "modelDeploymentName": { "value": "${MODEL_DEPLOYMENT_NAME=gpt-realtime}" },
    "modelName": { "value": "${MODEL_NAME=gpt-realtime}" },
    "modelVersion": { "value": "${MODEL_VERSION=2025-08-28}" },
    "modelSkuName": { "value": "${MODEL_SKU_NAME=GlobalStandard}" },
    "modelSkuCapacity": { "value": 1 },
    "cosmosSessionsTtlDays": { "value": 30 },
    "auditTtlDays": { "value": 2555 },
    "voiceMaxSessionMinutes": { "value": 20 },
    "voiceIdleSeconds": { "value": 30 },
    "featuresApim": { "value": false },
    "tagOwner": { "value": "${TAG_OWNER=platform@flint.local}" },
    "tagCostCenter": { "value": "${TAG_COST_CENTER=CC-FLINT-0001}" },
    "deployerPrincipalId": { "value": "${AZURE_PRINCIPAL_ID}" },
    "deployerPrincipalType": { "value": "${AZURE_PRINCIPAL_TYPE=User}" },
    "sweeperImageRef": { "value": "${SERVICE_SWEEPER_IMAGE_NAME=mcr.microsoft.com/azuredocs/containerapps-helloworld:latest}" }
  }
}
